{
  "name": "zoomcord",
  "version": "2.0.0",
  "description": "ZoomCord — Video Chat + Realtime Messaging with E2EE",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "pkg . --targets node20-win-x64 --output build/ZoomCord.exe"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "utils/**/*"
    ],
    "outputPath": "build"
  },
  "author": "ZoomCord Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.0",
    "socket.io": "^4.7.5",
    "peer": "^1.0.2",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "uuid": "^10.0.0",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.4.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "pkg": "^5.8.1"
  }
}